{
  "name": "@gpsoftware/jquery-event-calendar",
  "version": "2.0.2",
  "description": "A modern, lightweight and fully responsive Event Calendar plugin for jQuery",
  "main": "dist/umd/jquery.eventCalendar.js",
  "module": "dist/esm/jquery.eventCalendar.js",
  "types": "dist/umd/jquery.eventCalendar.d.ts",
  "files": ["dist", "README.md" ],
  "peerDependencies": {
    "jquery": ">=3.0.0",
    "moment": ">=2.0.0"
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:css": "sass src/scss/eventCalendar.scss dist/css/eventCalendar.css --style compressed",
    "build:umd": "tsc -p tsconfig.json",
    "minify:umd": "terser dist/umd/jquery.eventCalendar.js -o dist/umd/jquery.eventCalendar.min.js -c -m",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "npm-run-all clean build:css build:umd minify:umd build:esm",
    "test": "jest",
    "watch": "tsc -w"
  },
  "keywords": [
    "jquery",
    "calendar",
    "events",
    "plugin",
    "typescript"
  ],
  "author": "Gianpiero Caretti",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jquery": "^4.0.1",
    "@types/node": "^26.1.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jquery": "^4.0.0",
    "moment": "^2.30.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.0",
    "sass": "^1.101.0",
    "terser": "^5.48.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
